# EditorConfig — consistent formatting across all editors and IDEs.
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

# Python
[*.py]
indent_size = 4
max_line_length = 100

# TOML (pyproject.toml, uv.lock metadata)
[*.toml]
indent_size = 4

# YAML (.pre-commit-config.yaml, docker-compose.yml, GitHub Actions)
[*.{yml,yaml}]
indent_size = 2

# JSON
[*.json]
indent_size = 2

# Markdown — preserve trailing spaces (used for line breaks in some renderers)
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# Groovy (Jenkinsfile)
[Jenkinsfile]
indent_size = 4

# Makefile — tabs are required
[Makefile]
indent_style = tab

# Shell scripts
[*.sh]
indent_size = 4
