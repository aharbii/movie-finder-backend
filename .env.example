# =============================================================================
# backend (full-stack integration) — master environment template
# Copy to .env and fill in ALL values before running docker compose up.
#
# Sections:
#   [RAG TEAM]  — values output by rag_ingestion after a successful ingest run
#   [APP TEAM]  — managed by the backend app team
#
# Never commit .env to version control.
# =============================================================================


# =============================================================================
# PostgreSQL — session / user database [APP TEAM]
# Local dev: docker compose starts a postgres container with these values.
# Production: Azure Database for PostgreSQL Flexible Server.
# =============================================================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=movie_finder
DB_USER=movie_finder
DB_PASSWORD=                    # generate: openssl rand -hex 32
DATABASE_URL=postgresql://movie_finder:<DB_PASSWORD>@postgres:5432/movie_finder


# =============================================================================
# Qdrant Cloud — shared between chain (read) and rag_ingestion (write)
# [RAG TEAM] provides these after each ingestion run.
# Both backend and frontend always connect to the production Qdrant cluster.
# There is no local Qdrant container.
# =============================================================================
QDRANT_ENDPOINT=https://your-cluster.qdrant.io
QDRANT_API_KEY=                 # [RAG TEAM]
# Collection name and model MUST match what was used during ingestion
QDRANT_COLLECTION=movies        # [RAG TEAM]
EMBEDDING_MODEL=text-embedding-3-large  # [RAG TEAM]
EMBEDDING_DIMENSION=3072        # [RAG TEAM]


# =============================================================================
# LLM APIs — used by chain
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-
# Fast classifier model (confirmation node)
CLASSIFIER_MODEL=claude-haiku-4-5-20251001
# Reasoning model (refinement + Q&A agent)
REASONING_MODEL=claude-sonnet-4-6

OPENAI_API_KEY=sk-


# =============================================================================
# Chain tuning — optional, defaults shown
# =============================================================================
RAG_TOP_K=8
MAX_REFINEMENTS=3
IMDB_SEARCH_LIMIT=3
CONFIDENCE_THRESHOLD=0.3
LOG_LEVEL=INFO


# =============================================================================
# RAG Ingestion — only needed when running rag_ingestion locally or via CI
# Handled separately by the RAG team; not part of the backend or frontend.
# =============================================================================
KAGGLE_USERNAME=
KAGGLE_KEY=
VECTOR_STORE=qdrant


# =============================================================================
# Observability — LangSmith tracing (optional)
# =============================================================================
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=movie-finder


# =============================================================================
# App — FastAPI application layer [APP TEAM]
# =============================================================================
APP_SECRET_KEY=                 # JWT signing secret — generate: openssl rand -hex 32
APP_ENV=development             # development | staging | production
APP_PORT=8000
