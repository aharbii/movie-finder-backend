# Vector Store (Qdrant Cloud)
# NOTE: rag_ingestion uses QDRANT_ENDPOINT + QDRANT_API_KEY (not QDRANT_URL)
QDRANT_ENDPOINT=https://your-cluster.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key
# Collection name must match the embedding model used during ingestion
QDRANT_COLLECTION=text-embedding-3-large

# External Model Engines — OpenAI (embeddings)
OPENAI_API_KEY=sk-your-openai-key
# Embedding model must match what was used during rag_ingestion
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSION=3072

# External Model Engines — Anthropic (LLM chain nodes)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
# Fast classifier model (confirmation node)
CLASSIFIER_MODEL=claude-haiku-4-5-20251001
# Reasoning model (refinement + Q&A agent)
REASONING_MODEL=claude-sonnet-4-6

# Chain tuning
RAG_TOP_K=8
MAX_REFINEMENTS=3
IMDB_SEARCH_LIMIT=3
CONFIDENCE_THRESHOLD=0.3

# RAG Ingestion Authorizations (Kaggle — only needed for rag_ingestion/main.py)
KAGGLE_API_TOKEN=

# Observability Configuration (LangSmith)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_PROJECT=movie-finder
