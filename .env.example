# =============================================================================
# backend (full-stack integration) — master environment template
# Copy to .env and fill in ALL values before running docker compose up.
#
# Sections:
#   [RAG TEAM]  — values output by rag_ingestion after a successful ingest run
#   [IMDB TEAM] — provided by the imdbapi team
#   [APP TEAM]  — managed by the backend app team
#
# Never commit .env to version control.
# =============================================================================


# =============================================================================
# Qdrant — shared between rag_ingestion (write) and chain (read)
# [RAG TEAM] provides these after each ingestion run.
# =============================================================================
QDRANT_ENDPOINT=https://your-cluster.qdrant.io
QDRANT_API_KEY=
# Collection name and model MUST match what was used during ingestion
QDRANT_COLLECTION=movies
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSION=3072


# =============================================================================
# LLM APIs — used by chain
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-
# Fast classifier model (confirmation node)
CLASSIFIER_MODEL=claude-haiku-4-5-20251001
# Reasoning model (refinement + Q&A agent)
REASONING_MODEL=claude-sonnet-4-6

OPENAI_API_KEY=sk-


# =============================================================================
# IMDb API — used by chain via imdbapi-client
# [IMDB TEAM] provides these.
# =============================================================================
IMDB_API_KEY=
IMDB_BASE_URL=


# =============================================================================
# Chain tuning — optional, defaults shown
# =============================================================================
RAG_TOP_K=8
MAX_REFINEMENTS=3
IMDB_SEARCH_LIMIT=3
CONFIDENCE_THRESHOLD=0.3
LOG_LEVEL=INFO


# =============================================================================
# RAG Ingestion — only needed when running rag_ingestion locally or via CI
# =============================================================================
KAGGLE_USERNAME=
KAGGLE_KEY=
VECTOR_STORE=qdrant


# =============================================================================
# Observability — LangSmith tracing (optional)
# =============================================================================
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=movie-finder


# =============================================================================
# App — FastAPI application layer [APP TEAM]
# =============================================================================
APP_SECRET_KEY=                 # JWT signing secret — generate: openssl rand -hex 32
DATABASE_URL=./movie_finder.db  # bare path OR sqlite+aiosqlite:///./movie_finder.db
APP_ENV=development             # development | staging | production
APP_PORT=8000
