# =============================================================================
# movie-finder-backend — Docker-only local development environment template
#
# Copy this file to `.env` before running any `make ...` target.
#
# Scope of this template:
#   - Backend app stack owned by this repo
#   - Shared contract visibility for child repos that import the same secrets
#
# Child-repo-only workflows are intentionally NOT driven from here yet. The
# standalone rollout for `chain/`, `imdbapi/`, and `rag_ingestion/` is tracked
# in their own issues and will be folded back into the backend root later.
#
# Qdrant is external-only. Do not add a local Qdrant container or bring back
# the legacy `QDRANT_ENDPOINT` / `QDRANT_API_KEY` / `QDRANT_COLLECTION` names.
# The backend compose file exports those names internally as a temporary bridge
# until `movie-finder-chain#9` is merged.
#
# Never commit `.env` to version control.
# =============================================================================


# =============================================================================
# PostgreSQL — backend app local development
#
# Local Docker Compose:
#   - `postgres` service uses DB_* values below
#   - `POSTGRES_HOST_PORT` only affects your host machine binding
#   - the backend container always connects to `postgres:5432` internally
#
# Runtime contract:
#   - env var: `DATABASE_URL`
#   - Azure Key Vault item name: `postgres-url`
#   - Jenkins credential: not used by the current backend CI slice
#   - backend app uses this for both SessionStore and persistent LangGraph checkpoints
# =============================================================================
DB_HOST=postgres
DB_PORT=5432
POSTGRES_HOST_PORT=5432
DB_NAME=movie_finder
DB_USER=movie_finder
DB_PASSWORD=devpassword
DATABASE_URL=postgresql://movie_finder:devpassword@postgres:5432/movie_finder  # pragma: allowlist secret


# =============================================================================
# Qdrant Cloud — shared vector store (external only)
#
# Canonical contract from `../infrastructure/docs/qdrant-secret-model.md`:
#   - `QDRANT_URL`              read/write endpoint URL
#   - `QDRANT_API_KEY_RO`       read-only key for app + chain
#   - `QDRANT_COLLECTION_NAME`  shared collection identifier
#
# Secret storage:
#   - Azure Key Vault: `qdrant-url`, `qdrant-api-key-ro`, `qdrant-collection-name`
#   - Jenkins credentials: `qdrant-url`, `qdrant-api-key-ro`, `qdrant-collection-name`
# =============================================================================
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY_RO=
QDRANT_COLLECTION_NAME=movies


# =============================================================================
# RAG ingestion only — documented here for cross-repo alignment
#
# These values are part of the shared secret contract, but they are NOT injected
# into the backend app container in this iteration.
#
# Secret storage:
#   - Azure Key Vault: `qdrant-api-key-rw`, `kaggle-api-token` (future infra work)
#   - Jenkins: not used by the current backend CI slice
# =============================================================================
QDRANT_API_KEY_RW=
KAGGLE_API_TOKEN=


# =============================================================================
# LLM APIs — used by the backend app through the imported chain library
#
# Secret storage:
#   - Azure Key Vault: `anthropic-api-key`, `openai-api-key`
#   - Jenkins: not used by the current backend CI slice (stub values only there)
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-
# Fast classifier model used by the confirmation path.
CLASSIFIER_MODEL=claude-haiku-4-5-20251001
# Higher-capability reasoning model for refinement and Q&A.
REASONING_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=sk-


# =============================================================================
# Chain tuning — optional knobs for local experimentation
# =============================================================================
RAG_TOP_K=8
MAX_REFINEMENTS=3
IMDB_SEARCH_LIMIT=3
CONFIDENCE_THRESHOLD=0.3
LOG_LEVEL=INFO
# text (human-readable, default) or json (structured, for Azure Monitor / log pipelines)
LOG_FORMAT=text


# =============================================================================
# Observability — LangSmith tracing (optional)
#
# Secret storage:
#   - Azure Key Vault: `langsmith-api-key`
#   - Jenkins: not used by the current backend CI slice
# =============================================================================
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=movie-finder


# =============================================================================
# App — FastAPI application layer
#
# `BACKEND_HOST_PORT` only affects the host binding. Inside Docker Compose, the
# service still listens on `APP_PORT` and other containers still reach it by the
# compose service name.
#
# Secret storage:
#   - Azure Key Vault: `app-secret-key`
#   - Jenkins: not used by the current backend CI slice
# =============================================================================
# JWT signing secret. Generate with: openssl rand -hex 32
APP_SECRET_KEY=
APP_ENV=development
APP_PORT=8000
BACKEND_HOST_PORT=8000
CORS_ORIGINS=["http://localhost:4200","https://your-prod-domain.com"]
GLOBAL_RATE_LIMIT=100/minute
AUTH_RATE_LIMIT=5/minute
CHAT_RATE_LIMIT=20/minute
MAX_MESSAGE_LENGTH=2000
