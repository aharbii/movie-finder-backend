{
  // ── Python interpreter ────────────────────────────────────────────────────
  // uv creates the workspace virtualenv at backend/.venv after `uv sync`.
  // If the path shows "not found", run: uv sync --all-packages
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.terminal.activateEnvironment": true,

  // ── Ruff (linting + formatting) ───────────────────────────────────────────
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "explicit",
      "source.organizeImports.ruff": "explicit"
    }
  },
  "ruff.importStrategy": "fromEnvironment",

  // ── mypy ─────────────────────────────────────────────────────────────────
  "mypy-type-checker.importStrategy": "fromEnvironment",
  "mypy-type-checker.args": ["--strict"],

  // ── Editor ────────────────────────────────────────────────────────────────
  "editor.rulers": [100],
  "editor.tabSize": 4,
  "editor.insertSpaces": true,

  // ── File explorer — hide generated artifacts ──────────────────────────────
  "files.exclude": {
    "**/__pycache__": true,
    "**/.mypy_cache": true,
    "**/.ruff_cache": true,
    "**/*.pyc": true,
    "**/.pytest_cache": true,
    "**/dist": true,
    "**/*.egg-info": true
  },

  // ── Test discovery ────────────────────────────────────────────────────────
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": ["--asyncio-mode=auto", "-v"],
  "python.testing.unittestEnabled": false
}
