{
  // ── Backend root workflow ────────────────────────────────────────────────
  // Host commands go through `make ...` tasks.
  // Python-powered editor features assume VS Code is attached to the running
  // `backend` service container after `make up`.
  "python.defaultInterpreterPath": "/opt/venv/bin/python",
  "python.terminal.activateEnvironment": false,
  "python.envFile": "${workspaceFolder}/.env",

  // ── Editor intelligence ──────────────────────────────────────────────────
  // The backend app imports both `chain` and `imdbapi`, so expose those source
  // roots for navigation and symbol resolution inside the attached container.
  "python.analysis.extraPaths": [
    "${workspaceFolder}/app/src",
    "${workspaceFolder}/chain/src",
    "${workspaceFolder}/imdbapi/src"
  ],
  "python.analysis.autoImportCompletions": true,

  // ── Ruff (linting + formatting) ──────────────────────────────────────────
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "explicit",
      "source.organizeImports.ruff": "explicit"
    }
  },
  "ruff.importStrategy": "fromEnvironment",

  // ── mypy ─────────────────────────────────────────────────────────────────
  "mypy-type-checker.importStrategy": "fromEnvironment",
  "mypy-type-checker.args": ["--strict"],

  // ── Editor ergonomics ────────────────────────────────────────────────────
  "editor.rulers": [100],
  "editor.tabSize": 4,
  "editor.insertSpaces": true,

  // ── File explorer — hide generated artifacts ─────────────────────────────
  "files.exclude": {
    "**/__pycache__": true,
    "**/.mypy_cache": true,
    "**/.ruff_cache": true,
    "**/*.pyc": true,
    "**/.pytest_cache": true,
    "**/htmlcov": true,
    "**/dist": true,
    "**/*.egg-info": true
  },

  // ── Test Explorer — backend app only for this iteration ─────────────────
  // Child repo test/debug surfaces remain owned by the child issue rollouts.
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": ["app/tests/", "--asyncio-mode=auto", "-v"],
  "python.testing.cwd": "${workspaceFolder}",
  "python.testing.autoTestDiscoverOnSaveEnabled": true,
  "python.testing.unittestEnabled": false
}
