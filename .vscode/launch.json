{
  "version": "0.2.0",
  "configurations": [

    // ── Backend app (attached container) ───────────────────────────────────
    // Start the stack with `make up`, then use:
    //   Dev Containers: Attach to Running Container...
    // These launch configs are intentionally limited to the backend-owned app
    // slice in this iteration; child repo debug profiles stay with child issues.
    {
      "name": "app: FastAPI dev server (backend container)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["app.main:app", "--reload", "--host", "0.0.0.0", "--port", "8000"],
      "jinja": true,
      "envFile": "${workspaceFolder}/.env",
      "python": "/opt/venv/bin/python",
      "cwd": "${workspaceFolder}",
      "justMyCode": false
    },

    // ── pytest — backend app only ──────────────────────────────────────────
    // Tests point at the dedicated `movie_finder_test` database created by the
    // postgres init script under docker/postgres/init/.
    {
      "name": "pytest: app tests (backend container)",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["app/tests/", "--asyncio-mode=auto", "-v"],
      "env": {
        "DATABASE_URL": "postgresql://movie_finder:devpassword@postgres:5432/movie_finder_test" // pragma: allowlist secret
      },
      "envFile": "${workspaceFolder}/.env",
      "python": "/opt/venv/bin/python",
      "cwd": "${workspaceFolder}",
      "justMyCode": false
    },
    {
      "name": "pytest: current app test file (backend container)",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["${file}", "--asyncio-mode=auto", "-v"],
      "env": {
        "DATABASE_URL": "postgresql://movie_finder:devpassword@postgres:5432/movie_finder_test" // pragma: allowlist secret
      },
      "envFile": "${workspaceFolder}/.env",
      "python": "/opt/venv/bin/python",
      "cwd": "${workspaceFolder}",
      "justMyCode": false
    },
    {
      "name": "pytest: app tests with coverage (backend container)",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "app/tests/",
        "--asyncio-mode=auto",
        "-v",
        "--cov=app",
        "--cov-report=term-missing",
        "--cov-report=xml:app-coverage.xml",
        "--cov-report=html:htmlcov/app"
      ],
      "env": {
        "DATABASE_URL": "postgresql://movie_finder:devpassword@postgres:5432/movie_finder_test" // pragma: allowlist secret
      },
      "envFile": "${workspaceFolder}/.env",
      "python": "/opt/venv/bin/python",
      "cwd": "${workspaceFolder}",
      "justMyCode": false
    }
  ]
}
