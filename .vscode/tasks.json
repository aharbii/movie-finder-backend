{
  "version": "2.0.0",
  "tasks": [

    // ══════════════════════════════════════════════════════════════════════
    // Backend lifecycle — host tasks dispatch into the Docker-only Makefile.
    // Child repo task surfaces stay with their own issue-owned rollouts.
    // ══════════════════════════════════════════════════════════════════════
    {
      "label": "backend: init",
      "type": "shell",
      "command": "make init",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "backend: up",
      "type": "shell",
      "command": "make up",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "backend: down",
      "type": "shell",
      "command": "make down",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "backend: logs",
      "type": "shell",
      "command": "make logs",
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "backend: shell",
      "type": "shell",
      "command": "make shell",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },

    // ══════════════════════════════════════════════════════════════════════
    // Backend code quality — app-owned checks only for this iteration.
    // ══════════════════════════════════════════════════════════════════════
    {
      "label": "backend: lint",
      "type": "shell",
      "command": "make lint",
      "options": { "cwd": "${workspaceFolder}" },
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "backend: format",
      "type": "shell",
      "command": "make format",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "backend: typecheck",
      "type": "shell",
      "command": "make typecheck",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "backend: test",
      "type": "shell",
      "command": "make test",
      "options": { "cwd": "${workspaceFolder}" },
      "group": { "kind": "test", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "backend: test with coverage",
      "type": "shell",
      "command": "make test-coverage",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "test",
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "backend: pre-commit",
      "type": "shell",
      "command": "make pre-commit",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "backend: verify",
      "type": "shell",
      "command": "make check",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared" }
    }
  ]
}
